---
import Base from "@/layouts/Base.astro";
import NotionRenderer from "@/components/NotionRenderer.vue";
import PostHeader from "@/components/PostHeader.astro";
import { getPublishedPosts, getPageById, extractTextFromBlocks } from "@/lib/notion";
import { enrichBlocksWithOgp } from "@/lib/enrichBlocks";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map((post) => ({
    params: { id: post.id },
  }));
}

const { id } = Astro.params;
const data = await getPageById(id!);

if (!data) {
  return Astro.redirect("/404");
}

const { meta, blocks } = data;
await enrichBlocksWithOgp(blocks);

const description = extractTextFromBlocks(blocks);
const title = meta.title || description;
---

<Base title={title} description={description} ogType="article" oEmbedUrl={`/oembed/${id}.json`}>
  <article itemscope itemtype="https://schema.org/BlogPosting">
    <PostHeader meta={meta} />

    <NotionRenderer blocks={blocks} client:load />
  </article>
</Base>

<style>
  .post-cover {
    width: 100%;
    border-radius: 0.5rem;
    margin-bottom: 1.5rem;
    object-fit: cover;
    max-height: 400px;
  }
</style>
