---
import Base from "@/layouts/Base.astro";
import NotionRenderer from "@/components/NotionRenderer.vue";
import { getPublishedPosts, getPageById } from "@/lib/notion";
import { enrichBlocksWithOgp } from "@/lib/enrichBlocks";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map((post) => ({
    params: { id: post.id },
  }));
}

const { id } = Astro.params;
const data = await getPageById(id!);

if (!data) {
  return Astro.redirect("/404");
}

const { meta, blocks } = data;
await enrichBlocksWithOgp(blocks);

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString("ja-JP", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<Base title={meta.title}>
  <article>
    <header class="post-header">
      <h1 class="post-title">{meta.title}</h1>
      <div class="post-meta">
        <time>{formatDate(meta.lastEditedAt)}</time>
      </div>
    </header>

    <NotionRenderer blocks={blocks} client:load />
  </article>
</Base>

<style>
  .post-header {
    margin-bottom: 1rem;
  }
  .post-title {
    font-size: 2rem;
    font-weight: bold;
    line-height: 1.3;
    margin-bottom: 0.25rem;
  }
  .post-meta {
    color: var(--c-text-sub);
    font-size: 0.95rem;
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-wrap: wrap;
  }
  .post-cover {
    width: 100%;
    border-radius: 0.5rem;
    margin-bottom: 1.5rem;
    object-fit: cover;
    max-height: 400px;
  }

  @media (max-width: 576px) {
    .post-title {
      font-size: 1.5rem;
    }
  }
</style>
