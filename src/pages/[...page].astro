---
import type { GetStaticPathsOptions } from "astro";
import Base from "@/layouts/Base.astro";
import NotionRenderer from "@/components/NotionRenderer.vue";
import PostHeader from "@/components/PostHeader.astro";
import {
  getPublishedPostsWithBlocks,
  getBlocksBeforeDivider,
} from "@/lib/notion";
import { enrichBlocksWithOgp } from "@/lib/enrichBlocks";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const posts = await getPublishedPostsWithBlocks();

  for (const post of posts) {
    await enrichBlocksWithOgp(post.blocks);
  }

  return paginate(posts, { pageSize: 10 });
}

const { page } = Astro.props;
---

<Base title={page.currentPage === 1 ? "" : `Page ${page.currentPage}`}>
  <section class="posts-list">
    {
      page.data.map((post) => {
        const displayBlocks = getBlocksBeforeDivider(post.blocks);
        const hasDivider = displayBlocks.length < post.blocks.length;
        return (
          <article class="post-entry" itemscope itemtype="https://schema.org/BlogPosting">
            <PostHeader meta={post.meta} linkTitle />
            <div class="post-entry-body">
              <NotionRenderer blocks={displayBlocks} client:load />
            </div>
            {hasDivider && (
              <div class="post-entry-more">
                <a href={`/posts/${post.meta.id}`} class="post-entry-more-link">続きを読む</a>
              </div>
            )}
            <footer class="post-entry-footer text-body-secondary d-flex gap-2 justify-content-end">
              <a href={`/posts/${post.meta.id}/`} aria-label={post.meta.title ? `記事「${post.meta.title}」を読む` : "記事を読む"}>
                Permalink
              </a>
            </footer>
          </article>
        );
      })
    }

    {page.data.length === 0 && <p>記事がまだありません。</p>}
  </section>

  {
    page.lastPage > 1 && (
      <nav aria-label="ページナビゲーション" class="mt-4">
        <ul class="pagination justify-content-center">
          <li class:list={["page-item", { disabled: !page.url.prev }]}>
            <a class="page-link" href={page.url.prev ?? "#"}>&laquo; 前へ</a>
          </li>

          {Array.from({ length: page.lastPage }, (_, i) => i + 1).map((num) => (
            <li class:list={["page-item", { active: num === page.currentPage }]}>
              <a class="page-link" href={num === 1 ? "/" : `/${num}`}>{num}</a>
            </li>
          ))}

          <li class:list={["page-item", { disabled: !page.url.next }]}>
            <a class="page-link" href={page.url.next ?? "#"}>次へ &raquo;</a>
          </li>
        </ul>
      </nav>
    )
  }
</Base>

<style>
  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .post-entry {
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--c-border);
  }
  .post-entry:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .post-entry-more {
    margin-top: 1rem;
  }
  .post-entry-more-link {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--c-accent);
  }
  .post-entry-more-link::after {
    content: " →";
  }
  .post-entry-footer {
    margin-top: 2rem;
    font-size: 0.8rem;
  }
</style>
