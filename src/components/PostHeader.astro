---
import type { PostMeta } from "@/lib/notion";

interface Props {
  meta: PostMeta;
  linkTitle?: boolean;
}

const { meta, linkTitle = false } = Astro.props;

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString("ja-JP", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<header class="post-header">
  <div class="post-meta">
    <time>{formatDate(meta.lastEditedAt)}</time>
  </div>
  {
    meta.title &&
      (linkTitle ? (
        <h1 class="post-title">
          <a href={`/posts/${meta.id}/`}>{meta.title}</a>
        </h1>
      ) : (
        <h1 class="post-title">{meta.title}</h1>
      ))
  }
</header>

<style>
  .post-header {
    margin-bottom: 1rem;
  }
  .post-title {
    font-size: 2rem;
    font-weight: bold;
    line-height: 1.3;
    margin-bottom: 0.25rem;
  }
  .post-title a {
    color: var(--bs-body-color);
    text-decoration: none;
  }
  .post-title a:hover {
    color: var(--c-accent);
  }
  .post-meta {
    color: var(--c-text-sub);
    font-size: 0.95rem;
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: 0.6rem;
  }

  @media (max-width: 576px) {
    .post-title {
      font-size: 1.5rem;
    }
  }
</style>
