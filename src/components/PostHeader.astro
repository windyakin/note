---
import type { PostMeta } from "@/lib/notion";

interface Props {
  meta: PostMeta;
  linkTitle?: boolean;
}

const { meta, linkTitle = false } = Astro.props;

const notionColors: Record<string, { bg: string; text: string }> = {
  default: { bg: "#e3e2e0", text: "#55534e" },
  gray:    { bg: "#e3e2e0", text: "#55534e" },
  brown:   { bg: "#eee0da", text: "#65443c" },
  orange:  { bg: "#fad9a1", text: "#6e4e2a" },
  yellow:  { bg: "#fdecc8", text: "#705e35" },
  green:   { bg: "#dbeddb", text: "#1d6446" },
  blue:    { bg: "#d3e5ef", text: "#0f4c81" },
  purple:  { bg: "#e8deee", text: "#5c3a7e" },
  pink:    { bg: "#f5e0e9", text: "#862e5e" },
  red:     { bg: "#ffe2dd", text: "#9b2b26" },
};

function tagStyle(color: string): string {
  const c = notionColors[color] ?? notionColors.default;
  return `--tag-text:${c.text};--tag-bg:${c.bg}`;
}

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString("ja-JP", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}

// 公開日と最終更新日が同じ日付なら更新日は出さない
const publishedDate = formatDate(meta.firstPublishedAt);
const lastEditedDate = formatDate(meta.lastEditedAt);
const showLastEdited = publishedDate !== lastEditedDate;
---

<header class="post-header">
  <dl class="post-meta">
    <dt class="visually-hidden">公開日</dt>
    <dd>
      <time itemprop="datePublished" datetime={meta.firstPublishedAt}>{publishedDate}</time>
    </dd>
    {showLastEdited && (
      <>
        <dt>最終更新</dt>
        <dd>
          <time itemprop="dateModified" datetime={meta.lastEditedAt}>{lastEditedDate}</time>
        </dd>
      </>
    )}
  </dl>
  {
    meta.title &&
      (linkTitle ? (
        <h1 class="post-title" itemprop="headline">
          <a href={`/posts/${meta.id}/`}>{meta.title}</a>
        </h1>
      ) : (
        <h1 class="post-title" itemprop="headline">{meta.title}</h1>
      ))
  }
  {meta.tags.length > 0 && (
    <ul class="post-tags" aria-label="タグ">
      {meta.tags.map((tag) => (
        <li><a class="badge post-tag" href={`/tags/${tag.name}/`} style={tagStyle(tag.color)}>{tag.name}</a></li>
      ))}
    </ul>
  )}
</header>

<style>
  .post-header {
    margin-bottom: 1rem;
  }
  .post-title {
    font-size: 2rem;
    font-weight: bold;
    line-height: 1.3;
    margin-bottom: 0.25rem;
  }
  .post-title a {
    color: var(--bs-body-color);
    text-decoration: none;
  }
  .post-title a:hover {
    color: var(--c-accent);
  }
  .post-meta {
    color: var(--c-text-sub);
    font-size: 0.95rem;
    margin: 0 0 0.6rem;
  }
  .post-meta dt,
  .post-meta dd {
    display: inline;
    margin: 0;
  }
  /* 可視ラベルにのみ装飾を適用 (visually-hidden な dt は影響なし) */
  .post-meta dt:not(.visually-hidden) {
    margin-inline-start: 0.5rem;
  }

  .post-tags {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .post-tag {
    font-weight: normal;
    color: var(--tag-text);
    background: transparent;
    border: 1px solid var(--tag-text);
  }
  .post-tag:hover {
    background: var(--tag-bg);
    text-decoration: none;
  }

  @media (max-width: 576px) {
    .post-title {
      font-size: 1.5rem;
    }
  }
</style>
